# E-Commerce FastAPI Backend Environment Configuration
PORT=8000
HOST=0.0.0.0

# Database Configuration (Supabase PostgreSQL URL)
# Example: postgresql://postgres.xxxx:[YOUR-PASSWORD]@aws-0-us-west-1.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://postgres:[PASSWORD]@[HOST]:[PORT]/postgres

# Supabase Auth JWT Verification Secret
# Found in: Supabase Dashboard -> Settings -> API -> JWT Settings -> JWT Secret
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here
