# E-Commerce FastAPI Backend Configuration
PORT=8000
HOST=127.0.0.1

# Fallback to local SQLite database if Supabase is not configured yet
# To use Supabase PostgreSQL, replace this URL with your Supabase Transaction/Session pooler URL
DATABASE_URL=sqlite:///./ecommerce.db

# Offline JWT Verification Secret
# To obtain this: Supabase Dashboard -> Settings -> API -> JWT Settings -> JWT Secret
# Set a dummy secret for local testing
SUPABASE_JWT_SECRET=super-secret-supabase-jwt-key-change-me-in-production-12345
